<>
    doap:name "Simple" ;
    pedal:unitName "Unknown" ;
    pedal:unitModel "None" ;
    pedal:width 2652 ;
    pedal:height 2110 ;
    pedal:addressings <addressings.json> ;
    pedal:screenshot <screenshot.png> ;
    pedal:thumbnail <thumbnail.png> ;
    pedal:version 12 ;
    ingen:polyphony 1 ;
    ingen:arc _:b1 ,
              _:b2 ,
              _:b3 ,
              _:b4 ,
              _:b5 ,
              _:b6 ;
    ingen:block <CABINET> ,
                <neural_amp_modeler_lv2> ,
                <reverb> ,
                <rt_neural_generic> ,
                <toob_ml> ,
                <toob_nam> ,
                <toob_convolution_reverb> ;
    lv2:port <:bpb> ,
             <:bpm> ,
             <:rolling> ,
             <midi_separated_mode> ,
             <midi_loopback> ,
             <control_in> ,
             <control_out> ,
             <capture_1> ,
             <capture_2> ,
             <playback_1> ,
             <playback_2> ;
    lv2:extensionData <http://lv2plug.in/ns/ext/state#interface> ;
    a lv2:Plugin ,
        ingen:Graph ,
        pedal:Pedalboard .
